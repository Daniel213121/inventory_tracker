generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────

enum AuditAction {
  // Auth
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGIN_LOCKED
  LOGOUT
  SESSION_EXPIRED
  PASSWORD_CHANGED
  PASSWORD_RESET_REQUESTED

  // Accounts
  ACCOUNT_CREATED
  ACCOUNT_ACTIVATED
  ACCOUNT_DEACTIVATED

  // Inventory
  INVENTORY_CREATED
  INVENTORY_UPDATED
  INVENTORY_DELETED
  INVENTORY_IMPORTED

  // Movements
  MOVEMENT_STOCK_IN
  MOVEMENT_STOCK_OUT

  // Waybills
  WAYBILL_CREATED
  WAYBILL_PRINTED

  // Assets
  ASSET_CREATED
  ASSET_ASSIGNED
  ASSET_TRANSFERRED

  // Employees
  EMPLOYEE_CREATED
  EMPLOYEE_RESIGNED

  // Settings & profile
  SETTINGS_UPDATED
  PROFILE_UPDATED
}

enum Condition {
  NEW
  USED
  FAULTY
}

enum MovementType {
  IN
  OUT
}

enum AssetType {
  LAPTOP
  PHONE
  TABLET
  MONITOR
  OTHER
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  DAMAGED
  BEYOND_REPAIR
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  UNDER_REPAIR
  RETIRED
}

enum TransferReason {
  RESIGNATION
  BEYOND_REPAIR
  UPGRADE
  REASSIGNMENT
  OTHER
}

enum SerialStatus {
  IN_STOCK
  DISPATCHED
}

// ─── Company ──────────────────────────────────────────────────────────────

model Company {
  id                    String          @id @default(cuid())
  name                  String
  code                  String          @unique
  tagline               String
  taglineLine2          String
  fullName              String
  addressGhana          String
  addressUSA            String
  phoneGhana            String
  mobileGhana           String
  phoneUSA              String
  email                 String
  website               String
  brandSubtitle         String
  authoriserName        String
  authoriserDesignation String
  waybillSequence       Int             @default(0)
  logoUrl               String?

  inventory             InventoryItem[]
  movements             Movement[]
  waybills              Waybill[]
  branches              Branch[]
  employees             Employee[]
  assets                Asset[]
  transfers             AssetTransfer[]

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}

// ─── Category ─────────────────────────────────────────────────────────────

model Category {
  id        String          @id @default(cuid())
  value     String          @unique
  label     String
  isDefault Boolean         @default(false)

  inventory InventoryItem[]

  createdAt DateTime        @default(now())
}

// ─── Inventory Item ────────────────────────────────────────────────────────

model InventoryItem {
  id            String        @id @default(cuid())
  companyId     String
  company       Company       @relation(fields: [companyId], references: [id])

  categoryId    String
  category      Category      @relation(fields: [categoryId], references: [id])

  name          String
  brand         String
  model         String
  isSerialised  Boolean       @default(true)

  // Non-serialised: condition tracked by qty buckets
  qtyNew        Int           @default(0)
  qtyUsed       Int           @default(0)
  qtyFaulty     Int           @default(0)

  // Serialised: condition tracked per SerialUnit
  serialUnits   SerialUnit[]

  threshold     Int           @default(5)
  supplier      String?
  purchaseDate  DateTime
  description   String?
  notes         String?
  imageUrl      String?

  importBatchId String?
  importBatch   ImportBatch?  @relation(fields: [importBatchId], references: [id])

  movements     Movement[]

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([companyId])
  @@index([categoryId])
}

// ─── Serial Unit ──────────────────────────────────────────────────────────

model SerialUnit {
  id        String        @id @default(cuid())
  itemId    String
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  serial    String
  condition Condition
  status    SerialStatus  @default(IN_STOCK)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@unique([itemId, serial])
  @@index([itemId])
  @@index([status])
}

// ─── Movement ─────────────────────────────────────────────────────────────

model Movement {
  id                String        @id @default(cuid())

  itemId            String
  item              InventoryItem @relation(fields: [itemId], references: [id])

  companyId         String
  company           Company       @relation(fields: [companyId], references: [id])

  type              MovementType
  quantity          Int
  serialsDispatched String[]
  condBefore        Condition?
  condAfter         Condition?

  suppliedTo        String
  destinationCode   String?
  driverName        String
  notes             String?

  waybillId         String?
  waybill           Waybill?      @relation(fields: [waybillId], references: [id])

  movedBy           String
  movedAt           DateTime      @default(now())

  createdAt         DateTime      @default(now())

  @@index([itemId])
  @@index([companyId])
  @@index([waybillId])
  @@index([type])
}

// ─── Waybill ──────────────────────────────────────────────────────────────

model Waybill {
  id          String        @id @default(cuid())
  number      String        @unique
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id])

  date            DateTime
  suppliedTo      String
  destinationCode String
  driverName        String
  carNumber         String?
  deliveryLocation  String?
  itemIds           String[]

  generatedBy String
  generatedAt DateTime      @default(now())

  movements   Movement[]

  createdAt   DateTime      @default(now())

  @@index([companyId])
}

// ─── Import Batch ─────────────────────────────────────────────────────────

model ImportBatch {
  id         String          @id @default(cuid())
  filename   String
  rowCount   Int
  importedBy String
  companyId  String

  items      InventoryItem[]

  createdAt  DateTime        @default(now())
}

// ─── User ─────────────────────────────────────────────────────────────────

model User {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  password         String
  active           Boolean   @default(true)
  lastLogin        DateTime?
  sessionToken     String?   @unique
  sessionExpiresAt DateTime?
  failedAttempts   Int       @default(0)
  lockedUntil      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id           String      @id @default(cuid())
  action       AuditAction
  email        String
  userId       String?
  resourceType String?     // "User" | "InventoryItem" | "Movement" | "Waybill" | "Company"
  resourceId   String?
  ipAddress    String?
  userAgent    String?
  metadata     String?

  createdAt DateTime @default(now())

  @@index([email])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// ─── Branch ───────────────────────────────────────────────────────────────

model Branch {
  id        String     @id @default(cuid())
  name      String
  companyId String
  createdAt DateTime   @default(now())
  company   Company    @relation(fields: [companyId], references: [id])
  employees Employee[]
  assets    Asset[]

  @@index([companyId])
}

// ─── Employee ─────────────────────────────────────────────────────────────

model Employee {
  id               String            @id @default(cuid())
  companyId        String
  branchId         String
  employeeId       String?           @unique
  name             String
  jobTitle         String
  department       String
  email            String?
  phone            String?
  joinedAt         DateTime
  resignedAt       DateTime?
  active           Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  company          Company           @relation(fields: [companyId], references: [id])
  branch           Branch            @relation(fields: [branchId], references: [id])
  assetAssignments AssetAssignment[]

  @@index([companyId])
  @@index([branchId])
}

// ─── Asset ────────────────────────────────────────────────────────────────

model Asset {
  id              String            @id @default(cuid())
  companyId       String
  branchId        String
  assetTag        String            @unique
  type            AssetType
  brand           String
  model           String
  serial          String            @unique
  processor       String?
  ram             String?
  storage         String?
  operatingSystem String?
  software        String[]
  purchaseDate    DateTime?
  purchasePrice   Decimal?
  warrantyExpiry  DateTime?
  condition       AssetCondition
  status          AssetStatus
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  company         Company           @relation(fields: [companyId], references: [id])
  branch          Branch            @relation(fields: [branchId], references: [id])
  assignments     AssetAssignment[]
  transfers       AssetTransfer[]

  @@index([companyId])
  @@index([branchId])
  @@index([status])
  @@index([type])
}

// ─── Asset Assignment ─────────────────────────────────────────────────────

model AssetAssignment {
  id         String          @id @default(cuid())
  assetId    String
  employeeId String
  assignedAt DateTime        @default(now())
  assignedBy String
  returnedAt DateTime?
  returnedBy String?
  condition  AssetCondition?
  notes      String?
  asset      Asset           @relation(fields: [assetId], references: [id])
  employee   Employee        @relation(fields: [employeeId], references: [id])

  @@index([assetId])
  @@index([employeeId])
}

// ─── Asset Transfer ───────────────────────────────────────────────────────

model AssetTransfer {
  id               String          @id @default(cuid())
  referenceNumber  String          @unique
  assetId          String
  companyId        String
  fromEmployeeId   String?
  fromCondition    AssetCondition?
  returnedAt       DateTime?
  reason           TransferReason
  reasonNotes      String?
  toEmployeeId     String?
  assignedAt       DateTime?
  processedBy      String
  authorisedBy     String
  generatedAt      DateTime        @default(now())
  asset            Asset           @relation(fields: [assetId], references: [id])
  company          Company         @relation(fields: [companyId], references: [id])

  @@index([assetId])
  @@index([companyId])
  @@index([referenceNumber])
}
